# macOS
.DS_Store
**/.DS_Store

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/*
!build/*.py
!build/*.md
!build/Dockerfile.*
*.egg
venv/
venv_new/
.venv/
.build-venv/
.skill-build-venv/
.revue-core-build-venv/
.test-venv/
.venv-web/
.playwright-cli/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
*.xml

# IDE
.vscode/
.idea/
*.code-workspace

# Revue comment state (local only by default — set commit_state=true in .revue/config.toml to track)
.revue/

# Data
postgres-data/

# Web app
src/web/revue.db
src/web/.venv/

# Git worktrees (managed via git worktree, not tracked)
.worktrees/
.claude/worktrees/

# BMad planning artifacts (working docs, not deliverables)
_bmad-output/
context/ai-code-review-service

# Bitbucket Pipelines runner (machine-specific, contains credentials)
atlassian-bitbucket-pipelines-runner.tar.gz
atlassian-bitbucket-pipelines-runner/
.env.revue
.envrc

# Per-session Claude Code runtime state (sessionId/pid lock file)
.claude/scheduled_tasks.lock
_bmad/custom/config.user.toml

# Local SQLite dev DB — runtime data, must never be tracked (a tracked copy
# caused stale-schema crashes and clobbered live test accounts on git restore)
src/web/revue.db
src/web/revue.db-wal
src/web/revue.db-shm
# Root-level copy created when DATABASE_PATH defaults to "revue.db" (e.g. running
# tests/scripts from the repo root) — same artifact, different cwd.
/revue.db
/revue.db-wal
/revue.db-shm

# RuFlo / claude-flow local tooling state (machine-specific, not project files)
.claude-flow/
.swarm/
.claude/memory.db
.claude/memory.db-wal
.claude/memory.db-shm
*.rvf
*.rvf.lock
ruvector.db

# Node tooling (Claude Code statusline helper deps — never tracked)
node_modules/
